rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Phase 3: Primitives
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'azamashrapov2705@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Validation Blueprint for User
    function isValidUser(data, isCreate) {
      return data.keys().hasAll(['username', 'email', 'createdAt', 'isAdmin']) 
          && data.username is string && data.username.size() >= 3 && data.username.size() <= 128
          && data.email is string && data.email.size() <= 100
          && data.createdAt == request.time
          && data.isAdmin is bool
          && (isCreate ? data.isAdmin == false : true);
    }

    function isValidUserUpdate(data) {
      // Just enforcing basic types on update since users can only update specific fields
      // and admins can update everything.
      return (!('username' in data) || (data.username is string && data.username.size() >= 3 && data.username.size() <= 20))
          && (!('email' in data) || (data.email is string && data.email.size() <= 100))
          && (!('createdAt' in data) || data.createdAt == existing().createdAt)
          && (!('isAdmin' in data) || data.isAdmin is bool);
    }

    function isValidUsernameRegistry(data, userId) {
      return data.keys().hasAll(['userId']) 
          && data.keys().size() == 1
          && data.userId is string 
          && data.userId.size() <= 128
          && data.userId == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() 
        && isValidId(userId)
        && isOwner(userId)
        && isValidUser(incoming(), true)
        && (incoming().isAdmin == false || request.auth.token.email == 'azamashrapov2705@gmail.com')
        && existsAfter(/databases/$(database)/documents/usernames/$(incoming().username));
      
      allow update: if isSignedIn()
        && isValidId(userId)
        && isOwner(userId)
        && (
          isAdmin() ||
          incoming().diff(existing()).affectedKeys().hasOnly(['username', 'email', 'bio', 'fullName', 'links', 'photoUrl', 'isAdmin'])
        );
        
      allow delete: if isAdmin();

      // Subcollection for chat data
      match /data/chats {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /friend_requests/{friendId} {
        allow read: if isOwner(userId) || isOwner(friendId);
        allow create: if isSignedIn() && isOwner(friendId);
        allow update, delete: if isOwner(userId) || isOwner(friendId) || isAdmin();
      }
      
      match /friends/{friendId} {
        allow read: if isOwner(userId) || isOwner(friendId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /usernames/{usernameId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && isValidId(usernameId)
        && existsAfter(/databases/$(database)/documents/users/$(request.auth.uid));

      allow delete: if isSignedIn() && (isAdmin() || isOwner(existing().userId));
    }

    match /global_messages/{messageId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /direct_messages/{chatId} {
      // Must be a participant to read
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      // Allow create if auth uid is in participants
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/direct_messages/$(chatId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/direct_messages/$(chatId)).data.participants 
                      && incoming().senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
